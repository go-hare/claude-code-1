{
  "name": "@go-hare/mcp-chrome-bridge",
  "version": "3.0.2",
  "description": "Chrome Native-Messaging host (Node) — MCP + message bridge",
  "main": "dist/index.js",
  "bin": {
    "mcp-chrome-bridge": "./dist/cli.js",
    "mcp-chrome-stdio": "./dist/mcp/mcp-server-stdio.js"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts,js,json --ignore dist/ --exec \"npm run build && npm run register:dev\"",
    "build": "bun run  src/scripts/build.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint 'src/**/*.{js,ts}'",
    "lint:fix": "eslint 'src/**/*.{js,ts}' --fix",
    "format": "prettier --write 'src/**/*.{js,ts,json}'",
    "register:dev": "node dist/scripts/register-dev.js",
    "postinstall": "node dist/scripts/postinstall.js"
  },
  "files": [
    "dist",
    "!dist/node_path.txt"
  ],
  "preferGlobal": true,
  "keywords": [
    "mcp",
    "chrome",
    "browser"
  ],
  "author": "hangye",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "commander": "^13.1.0",
    "hono": "^4.12.12"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "chrome-mcp-shared": "^1.0.2",
    "@types/chrome": "^0.0.318",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.17",
    "@typescript-eslint/parser": "^8.31.1",
    "cross-env": "^7.0.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.1",
    "nodemon": "^3.1.10",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
